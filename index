/* ── 상태 관리 ── */
let selectedOptions = [null, null, null]; 
let activeSecs = []; 
let ST = []; 
let cur = 0; 
let isMenuMode = true;

function init(){ renderDots(); renderCard(); }

function toggleSelect(catIdx, optIdx) {
  selectedOptions[catIdx] = (selectedOptions[catIdx] === optIdx) ? null : optIdx;
  renderCard();
}

function startPractice() {
  if (selectedOptions.includes(null)) { alert("모든 항목에서 주제를 하나씩 골라주세요!"); return; }
  activeSecs = [
    MASTER_POOL[0].options[selectedOptions[0]],
    MASTER_POOL[1].options[selectedOptions[1]],
    ...MASTER_POOL[2].options[selectedOptions[2]].pathData
  ];
  ST = activeSecs.map(() => ({ stage: 0, done: [false, false, false] }));
  cur = 0; isMenuMode = false;
  buildDraft(); renderDots(); renderCard();
}

function renderDots(){
  const sdots = document.getElementById('sdots');
  if(isMenuMode) { sdots.innerHTML = ""; return; }
  sdots.innerHTML = activeSecs.map((s, i) => {
    const cls = ST[i].done.every(Boolean) ? 'done' : i === cur ? 'active' : '';
    return `<div class="sdot ${cls}" onclick="cur=${i};renderCard();renderDots();"><div class="dot-c">${i+1}</div></div>`;
  }).join('');
}

function renderCard() {
  const body = document.getElementById('sbody');
  if (isMenuMode) {
    document.querySelector('.stage-nav').style.display = "none";
    const picked = selectedOptions.filter(v => v !== null).length;
    body.innerHTML = `<div class="menu-guide">💡 각 카테고리에서 원하는 주제를 <b>하나씩</b> 선택하세요. 여러 선택지 중 자기에게 어울리는 것을 고르면 됩니다! (${picked}/3 선택됨)</div>` +
      MASTER_POOL.map((cat, cIdx) => `
      <div class="opt-grp">
        <div class="opt-grp-ttl">${cat.category} <span style="color:${selectedOptions[cIdx]!==null?'var(--ok)':'#bbb'};font-size:.78rem;margin-left:4px;">${selectedOptions[cIdx]!==null?'✓ 선택됨':'선택 필요'}</span></div>
        <div class="opt-wrap">
          ${cat.options.map((opt, oIdx) => `<button class="abtn ${selectedOptions[cIdx]===oIdx?'abtn-p':'abtn-s'}" onclick="toggleSelect(${cIdx}, ${oIdx})">${opt.ttl}</button>`).join('')}
        </div>
      </div>`).join('') + `<button class="abtn abtn-g" style="width:100%; padding:15px; margin-top:8px;" onclick="startPractice()">🚀 연습 시작하기</button>`;
    return;
  }
  document.querySelector('.stage-nav').style.display = "flex";
  const s = activeSecs[cur], st = ST[cur];
  document.getElementById('sbadge').textContent = `섹션 ${cur+1}`;
  document.getElementById('seval').textContent = s.eval || "";
  document.getElementById('sttl').textContent = s.ttl;
  document.getElementById('stabs').innerHTML = ['이해','연습','완성'].map((l,i)=>`<button class="stab s${i+1} ${i===st.stage?'on':''} ${st.done[i]?'ck':''}" onclick="ST[cur].stage=${i};renderCard();">${l}</button>`).join('');
  
  if(st.stage===0) body.innerHTML = `<div class="lrn-ko">${s.ko}</div><div class="lrn-en">${s.enD}</div><div class="tip-box">💡 ${s.tip}</div>`;
  else if(st.stage===1) renderPractice(s, cur, body);
  else renderWrite(s, cur, body);
}

function renderPractice(s, idx, body){
  let fl = `<div class="fill-line">`;
  s.fill.parts.forEach((p,j)=> fl += (typeof p==='string' ? p : `<input class="binp" id="bi-${idx}-${j}" oninput="chkFill(${idx})">`));
  body.innerHTML = fl + `</div><div class="scr-ans" id="sa-${idx}"><span class="empty-msg">단어를 클릭하세요</span></div><div class="scr-pool" id="sp-${idx}"></div>`;
  const pool = document.getElementById(`sp-${idx}`);
  [...s.scr.w].sort(()=>Math.random()-0.5).forEach(w => {
    const c = document.createElement('span'); c.className='chip'; c.textContent=w;
    c.onclick=()=>{ document.getElementById(`sa-${idx}`).appendChild(c); if(document.getElementById(`sa-${idx}`).querySelector('.empty-msg')) document.getElementById(`sa-${idx}`).querySelector('.empty-msg').remove(); chkScr(idx); };
    pool.appendChild(c);
  });
}

function chkFill(idx){
  let ok = true;
  activeSecs[idx].fill.parts.forEach((p,j)=>{ if(typeof p!=='string'){ const v = document.getElementById(`bi-${idx}-${j}`).value; if(v.toLowerCase().trim()!==p.b.toLowerCase()) ok=false; }});
  if(ok) { ST[idx].done[1]=true; renderDots(); renderCard(); }
}

function chkScr(idx){
  const ws = Array.from(document.getElementById(`sa-${idx}`).querySelectorAll('.chip')).map(c=>c.textContent);
  if(ws.join(' ') === activeSecs[idx].scr.a.join(' ')){ ST[idx].done[1]=true; renderDots(); renderCard(); }
}

function renderWrite(s, idx, body){
  body.innerHTML = `<textarea class="wrt-area" id="wt-${idx}" oninput="chkWrite(${idx})"></textarea><div class="fb" id="wfb-${idx}"></div>`;
}

function chkWrite(idx){
  if(activeSecs[idx].re.test(document.getElementById(`wt-${idx}`).value)){ ST[idx].done[2]=true; renderDots(); renderCard(); }
}

function nextStep(){ if(ST[cur].stage<2) ST[cur].stage++; else if(cur<activeSecs.length-1) cur++; else document.getElementById('summary').style.display="block"; renderCard(); renderDots(); }
function prevSect(){ if(ST[cur].stage>0) ST[cur].stage--; else if(cur>0) cur--; else isMenuMode=true; renderCard(); renderDots(); }

function buildDraft(){ document.getElementById('draft-body').innerHTML = activeSecs.map((s,i)=>`<textarea class="ds-area" id="da-${i}" oninput="updWC()" placeholder="${s.en}"></textarea>`).join(''); }

function updWC(){
  let tot = 0; activeSecs.forEach((_,i)=>tot+=document.getElementById(`da-${i}`).value.split(/\s+/).filter(w=>w).length);
  document.getElementById('wc-num').textContent = tot;
  document.getElementById('wc-grade').textContent = tot>=80 ? 'A (10점)' : 'E (6점)';
  document.getElementById('wc-grade').className = `wc-grade ${tot>=80?'wc-A':'wc-E'}`;
}

function copyDraft(){ navigator.clipboard.writeText(activeSecs.map((_,i)=>document.getElementById(`da-${i}`).value).join(' ')); alert('복사되었습니다!'); }

init();
</script>
